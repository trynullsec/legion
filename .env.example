# DATABASE_URL is the source of truth for the daemon's Postgres connection.
# The host port (5434) must match the port docker compose publishes; set
# LEGION_PG_PORT before `docker compose up` to use another, and keep this URL
# in sync. (The npx installer handles port conflicts and this sync for you.)
DATABASE_URL=postgres://legion:legion@localhost:5434/legion
OPENROUTER_API_KEY=sk-or-...

# M6d open missions (read-only web research). Tavily is the pinned provider
# in v0.1 — one key drives both web_search and web_extract.
LEGION_SEARCH_PROVIDER=tavily
LEGION_SEARCH_API_KEY=tvly-...
