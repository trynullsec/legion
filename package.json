{
  "name": "agent-legion",
  "private": true,
  "packageManager": "pnpm@10.30.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "migrate": "pnpm --filter @legion/db migrate",
    "build": "turbo run build",
    "dev": "pnpm --filter @legion/board build && pnpm --filter @legion/daemon dev",
    "test": "turbo run test --concurrency=1",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
